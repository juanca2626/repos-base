{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^7.1.3",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "ext-soap": "*",
    "aws/aws-sdk-php": "3.133",
    "barryvdh/laravel-cors": "^0.11.4",
    "claviska/simpleimage": "^3.3",
    "doctrine/dbal": "^2.9",
    "fideloper/proxy": "^4.0",
    "giggsey/libphonenumber-for-php": "^8.13",
    "guidocella/eloquent-insert-on-duplicate-key": "^2.2",
    "guzzlehttp/guzzle": "^6.4",
    "ixudra/curl": "^6.18",
    "jeremykenedy/laravel-roles": "^1.6",
    "jrm2k6/cloudder": "^0.7.0",
    "laravel/framework": "5.8.38",
    "laravel/tinker": "^1.0",
    "league/flysystem-aws-s3-v3": "~1.0",
    "maatwebsite/excel": "^3.1",
    "owen-it/laravel-auditing": "^10.0",
    "phpoffice/phpword": "^0.17.0",
    "sendinblue/api-v3-sdk": "7.x.x",
    "sentry/sentry-laravel": "^2.7",
    "spatie/laravel-activitylog": "^3.5",
    "spatie/laravel-permission": "^2.37",
    "tourcms/tourcms-php": "3.1.*",
    "twilio/sdk": "^6.38",
    "tymon/jwt-auth": "^1.0.0-rc.4.1"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^3.2",
    "beyondcode/laravel-dump-server": "^1.0",
    "exussum12/coverage-checker": "^0.11.1",
    "filp/whoops": "^2.0",
    "fzaninotto/faker": "^1.4",
    "mockery/mockery": "^1.0",
    "nunomaduro/collision": "^2.0",
    "phpunit/phpunit": "^7.5",
    "squizlabs/php_codesniffer": "3.*"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Helpers/Helper.php"
    ],
    "classmap": [
      "database/seeds",
      "database/factories"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  }
}
